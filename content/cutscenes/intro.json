    {"type": "animate", "entity": "", "property": "cameraRotation",
      "from": -3.0, "to": 0.0, "duration": 0.01, "easing": "Linear"},
    {"type": "animate", "entity": "", "property": "cameraX",
      "from": "cx", "to": "cx", "duration": 0.01, "easing": "Linear"},

    {"type": "clearPersistent"},
    {"type": "postProcess", "corruption": 0},

    {"_comment": "Iris open — reveal the title on a clean, empty stage"},
    {"type": "transition", "kind": "irisOpen", "duration": 1.5, "color": [0,0,0], "easing": "EaseOutCubic"},

    {"_comment": "THE TITLE — massive, centered, crimson"},
    {"type": "text", "text": "HELLO, CRUEL WORLD.",
      "position": ["cx - 280 * s", "cy - 40 * s"],
      "charSize": "56 * s", "color": [160,30,30], "charsPerSec": 35, "waitForInput": false},

