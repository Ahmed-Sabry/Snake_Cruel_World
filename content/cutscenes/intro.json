      {"type": "animate", "entity": "sB3", "property": "corruption",
        "from": 0.3, "to": 0.5, "duration": 1.8, "easing": "EaseInQuad"},
      {"type": "particles", "kind": "inkDrips", "position": ["cx - 80 * s", "20 * s"], "color": [160,30,30], "count": 10},
      {"type": "particles", "kind": "inkDrips", "position": ["cx + 60 * s", "15 * s"], "color": [160,30,30], "count": 8},
      {"type": "particles", "kind": "inkDrips", "position": ["cx", "10 * s"], "color": [160,30,30], "count": 6}
    ]},

    {"_comment": "Urgent narration with impact"},
    {"type": "parallel", "actions": [
      {"type": "text", "text": "And with every apple...",
        "position": ["cx - 180 * s", "h * 0.15"],
        "charSize": "32 * s", "color": [180,50,40], "charsPerSec": 28, "waitForInput": false},
      {"type": "sound", "sound": "wall_death"},
      {"type": "particles", "kind": "inkSplat", "position": ["cx", "cy"], "color": [180,50,40], "count": 30},
      {"type": "shake", "duration": 0.4, "intensity": 6}
    ]},

    {"type": "parallel", "actions": [
      {"type": "text", "text": "...the world grew crueler.",
        "position": ["cx - 220 * s", "h * 0.25"],
        "charSize": "40 * s", "color": [180,50,40], "charsPerSec": 26, "waitForInput": false},
