    {"_comment": "========== ACT 8 — FADE OUT =========="},

    {"type": "clearPersistent"},

    {"_comment": "Dissolve to black — the world is gone"},
    {"type": "transition", "kind": "dissolve", "duration": 2.5, "color": [0,0,0], "easing": "EaseInCubic"}
  ]
}
