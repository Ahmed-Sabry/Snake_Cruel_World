      {"type": "particles", "kind": "inkDrips", "position": ["cx", "10 * s"], "color": [160,30,30], "count": 8}
    ]},

    {"type": "wait", "duration": 1.5},

    {"_comment": "========== ACT 7 — THE TITLE =========="},
    {"_comment": "Everything is destroyed. From the ashes: the title."},

    {"type": "clearPersistent"},

    {"type": "postProcess", "fromCorruption": 0.65, "toCorruption": 1.0,
      "duration": 0.5, "easing": "EaseInCubic", "inkBleed": true, "chromatic": true, "psychedelic": true},

    {"_comment": "Destroy EVERYTHING — world, snake, ruled lines, margin"},
    {"type": "parallel", "actions": [
      {"type": "sound", "sound": "phase_advance"},
      {"type": "shake", "duration": 1.0, "intensity": 14},
      {"type": "destroy", "name": "border"},
      {"type": "destroy", "name": "sHead"},
      {"type": "destroy", "name": "sB1"},
      {"type": "destroy", "name": "sB2"},
      {"type": "destroy", "name": "sB3"},
      {"type": "destroy", "name": "line1"},
      {"type": "destroy", "name": "line2"},
      {"type": "destroy", "name": "line3"},
      {"type": "destroy", "name": "line4"},
      {"type": "destroy", "name": "line5"},
      {"type": "destroy", "name": "margin"},
      {"type": "particles", "kind": "inkSplat", "position": ["cx", "cy"], "color": [180,50,40], "count": 40},
