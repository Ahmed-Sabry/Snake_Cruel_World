      {"type": "shake", "duration": 1.0, "intensity": 10},
      {"type": "animate", "entity": "border", "property": "colorR",
        "from": 60, "to": 160, "duration": 1.8, "easing": "EaseInCubic"},
      {"type": "animate", "entity": "border", "property": "colorG",
        "from": 50, "to": 30, "duration": 1.8, "easing": "EaseInCubic"},
      {"type": "animate", "entity": "border", "property": "colorB",
        "from": 45, "to": 30, "duration": 1.8, "easing": "EaseInCubic"},
      {"type": "animate", "entity": "sHead", "property": "corruption",
        "from": 0.3, "to": 0.5, "duration": 1.8, "easing": "EaseInQuad"},
      {"type": "animate", "entity": "sB1", "property": "corruption",
        "from": 0.3, "to": 0.5, "duration": 1.8, "easing": "EaseInQuad"},
